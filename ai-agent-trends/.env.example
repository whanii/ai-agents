### Optional: use OpenAI API first when an API key is available.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.4

### Optional: choose a specific Codex CLI model for the secondary fallback path.
CODEX_MODEL=

### Optional: set an explicit Codex CLI executable path if PATH lookup is unreliable.
CODEX_CLI_PATH=
